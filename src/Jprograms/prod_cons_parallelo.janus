procedure producer(channel ch, int n)
    local int i = 0
    from i = 0 loop
        i += 1
        local int item = 0
            item += i
            show(item)
            ssend(item, ch)
        delocal int item = 0
    until i = n
    delocal int i = n

procedure consumer(channel ch, stack result, int n)
    local int i = 0
    from i = 0 loop
        local int item = 0
            srecv(item, ch)
            show(item)
            push(item, result)
        delocal int item = 0
        i += 1
    until i = n
    delocal int i = n

procedure main()
    local channel ch = empty
    stack result
    local int n = 5
    par
        call producer(ch, n)
    and
        call consumer(ch, result, n)
    rap
    delocal int n = 5
    delocal channel ch = empty