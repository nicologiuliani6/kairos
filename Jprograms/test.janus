procedure fib_iter(int x1, int x2, int n)
    local int i = 0
    local int tmp = 0

    x1 += 1
    x2 += 1

    i += n

    from i = n loop
        x1 += x2
        x1 <=> x2
        i -= 1
    until i = 0

    delocal int tmp = 0
    delocal int i = 0


procedure main()
    int Fib_of_n
    int Fib_of_n_minus_1
    int n
    n+=40
    call fib_iter(Fib_of_n_minus_1, Fib_of_n, n)
    show(Fib_of_n)
    show(Fib_of_n_minus_1)
    show(n)
    uncall fib_iter(Fib_of_n_minus_1, Fib_of_n, n)
    show(Fib_of_n)
    show(Fib_of_n_minus_1)
    show(n)