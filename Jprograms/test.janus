procedure run(channel ch, int n1, int n2)
    par
        ssend(n1, ch) //n1=0
    and
        srecv(n2, ch) //n2=5
    and
        ssend(n2, ch) //n2=0
     and
        srecv(n1, ch) //n1=5
    rap

procedure main()
    channel ch
    int n1
    n1+=5
    int n2
    call run(ch, n1, n2)
    uncall run(ch, n1, n2)