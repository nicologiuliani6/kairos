procedure mod(int x, int m, int q)
    from x >= m loop
        x -= m
        q += 1
    until x < m

procedure encrypt(int msg, int key)
    local int q = 0
    local int modulus = 256
        msg += key
        call mod(msg, modulus, q)
    delocal int modulus = 256
    delocal int q = 0

procedure main()
    local int msg = 0
    local int key = 17
    from msg == 0 loop
            show(msg)
        call encrypt(msg, key)
            show(msg)
        uncall encrypt(msg, key)
            //show(msg)
        msg+=1
    until msg == 10
    delocal int key = 17
    delocal int msg = 10