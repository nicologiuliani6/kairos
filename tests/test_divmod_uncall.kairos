// Smoke: call + uncall __mn_divmod_nonneg (prelude divmod + move_int).
procedure __mn_move_int(int dst, int src, stack __mn_hist, stack __mn_scratch)
    local stack __mn_g = nil
    push(src, __mn_g)
    pop(dst, __mn_g)
    delocal stack __mn_g = nil

procedure __mn_divmod_nonneg(int a, int b, int q, int r, stack __mn_hist, stack __mn_scratch)
    call __mn_move_int(r, a, __mn_hist, __mn_scratch)
    local int saved_r = 0
    saved_r += r
    if saved_r >= b then
        from q == 0 loop
            r -= b
            q += 1
        until r < b
    fi saved_r >= b
    push(saved_r, __mn_hist)
    delocal int saved_r = 0

procedure main()
    stack __mn_hist
    stack __mn_scratch
    local int a = 0
    local int b = 0
    local int q = 0
    local int r = 0
    a += 10
    b += 3
    call __mn_divmod_nonneg(a, b, q, r, __mn_hist, __mn_scratch)
    uncall __mn_divmod_nonneg(a, b, q, r, __mn_hist, __mn_scratch)
    delocal int r = 0
    delocal int q = 0
    delocal int b = 3
    delocal int a = 10
