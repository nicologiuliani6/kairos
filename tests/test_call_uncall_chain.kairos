// CALL / UNCALL annidati, parametri per riferimento
procedure increment(int x)
    x += 5

procedure apply_twice(int a, int b)
    call increment(a)
    call increment(b)
    a += b

procedure main()
    local int a = 3
    local int b = 7
    show(a)
    show(b)
    call apply_twice(a, b)
    show(a)
    show(b)
    uncall apply_twice(a, b)
    show(a)
    show(b)
    delocal int b = 7
    show(a)
    delocal int a = 3
