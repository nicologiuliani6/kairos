procedure main()
    channel c
    int x11
    x11+=11
    int x12
    x12+=12
    int x21
    int x22
    par 
        show(x11)
        ssend(x11, c)
        show(x11)
    and
        par 
            show(x12)
            ssend(x12, c)
            show(x12)
        and
            show(x21)
            srecv(x21, c)
            show(x21)
            show(x22)
            srecv(x22, c)
            show(x22)
        rap
    rap