procedure __mn_move_int(int dst, int src, stack __mn_hist, stack __mn_scratch)
    local stack __mn_g = nil
    push(src, __mn_g)
    pop(dst, __mn_g)
    delocal stack __mn_g = nil

procedure main()
    stack __mn_hist
    stack __mn_scratch
    local int a = 0
    local int r = 0
    a += 10
    call __mn_move_int(r, a, __mn_hist, __mn_scratch)
    uncall __mn_move_int(r, a, __mn_hist, __mn_scratch)
    delocal int r = 0
    delocal int a = 10
