// Ricorsione encrypt + uncall (sequenziale: parallelismo reale richiederebbe canali)

procedure encrypt(int m, int k)
    if k == 0 then
    else
        m += k
        k -= 1
        call encrypt(m, k)
    fi k == 0

procedure main()
    local int key = 17
    local int msg = 0
    show(msg)
    show(key)
    call encrypt(msg, key)
    show(msg)
    show(key)
    uncall encrypt(msg, key)
    show(msg)
    show(key)
    delocal int msg = 0
    delocal int key = 17
